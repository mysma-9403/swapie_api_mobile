# Application
APP_NAME=Swapie
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_URL=https://api.swapie.app
APP_DEBUG=false
APP_WORKERS=4

# Database (MySQL)
DATABASE_URL=mysql://user:password@127.0.0.1:3306/swapie
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# InPost API
INPOST_API_BASE_URL=https://api.inpost-group.com/points
INPOST_API_TOKEN=

# Orlen Paczka API
ORLEN_API_BASE_URL=https://api.orlenpaczka.pl
ORLEN_API_TOKEN=

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# AWS S3 / DigitalOcean Spaces (file storage)
S3_ENDPOINT=https://ams3.digitaloceanspaces.com
S3_BUCKET=swapie-media
S3_REGION=ams3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_URL=https://swapie-media.ams3.digitaloceanspaces.com

# Mail (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@swapie.app
SMTP_FROM_NAME=Swapie

# RabbitMQ (Message Queue)
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Redis (caching & rate limiting)
REDIS_URL=redis://127.0.0.1:6379

# SMS Provider
SMS_API_KEY=
SMS_API_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# reCAPTCHA
RECAPTCHA_SECRET=

# Lagano Library API (book/board game data, same server, no API key needed)
BOOK_API_URL=https://library.lagano.pl

# Logging
RUST_LOG=swapie_backend=info,actix_web=info

# Demo mode
DEMO_MODE=false
